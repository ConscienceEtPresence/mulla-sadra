{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mulla-sadra-fiche.schema.json",
  "title": "Fiche éditoriale (concept | notion) — édition numérique des Asfār",
  "description": "Garde-fou LÉGER + documentation du vocabulaire éditorial de Brahms. Permissif (additionalProperties:true) : l'éditeur rédige librement. Le vrai contrôle qualité = validate_fiches.py (résolution des références dans le référentiel + liens croisés). Deux formes acceptées : concept (identité à plat) et notion (identité + bloc enrichissement_editorial).",
  "type": "object",
  "additionalProperties": true,
  "required": ["id"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "type": { "enum": ["concept", "notion"] },
    "statut": { "type": "string", "description": "ex. ebauche | editorial | editorial_summary | revu | valide" },
    "domaine": { "type": ["string", "null"] },
    "voyage": { "type": ["integer", "null"], "minimum": 1, "maximum": 4 },

    "comment": { "type": "string", "description": "champ conventionnel : identité arabe non vocalisée" },
    "ar": { "type": "string" },
    "ar_vocalise": { "type": ["string", "null"] },
    "translit": { "type": "string" },
    "fr": { "type": "string" },
    "en": { "type": ["string", "null"] },
    "racine": { "type": ["string", "null"] },
    "sens_litteral": { "type": ["string", "null"] },
    "terme": { "type": "object", "additionalProperties": true, "description": "identité groupée (variante à l'identité à plat)" },

    "definition_courte": { "type": ["string", "object"] },
    "definition_longue": { "type": ["string", "object"] },

    "notions": { "type": "array", "items": { "type": "string" } },
    "concepts_lies": { "type": "array", "items": { "type": "string" } },
    "prerequis": { "type": "array", "items": { "type": "string" } },
    "pour_aller_plus_loin": { "type": "array", "items": { "type": "string" } },

    "premiere_apparition": {
      "description": "objet {voyage} OU {volume,...} OU liste d'adresses. Résolu dans le référentiel si `volume` présent.",
      "type": ["object", "array"]
    },
    "references": { "type": "array", "items": { "$ref": "#/$defs/reference" } },
    "developpements": { "type": "array", "items": { "$ref": "#/$defs/reference" } },

    "enrichissement_editorial": {
      "description": "Bloc doctrinal (notions). Vocabulaire de l'éditeur — documenté ci-dessous, non contraint.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "definition_philosophique": { "$ref": "#/$defs/bloc_edito" },
        "enjeu": { "type": "object", "additionalProperties": true },
        "prerequis": { "type": "array", "items": { "type": "string" } },
        "ouvre_vers": { "type": "array", "items": { "type": "string" } },
        "lexique": { "type": "array", "items": { "type": "object" } },
        "contresens_expliques": { "type": "array", "items": { "type": "object" } },
        "questions_de_lecture": { "type": "array", "items": { "type": "string" } },
        "comparaisons_historiques": { "type": "array", "items": { "type": "object" } },
        "niveau_difficulte": { "type": "object", "additionalProperties": true },
        "carte_conceptuelle": {
          "type": "object", "additionalProperties": true,
          "properties": {
            "avant": { "type": "array", "items": { "type": "string" } },
            "centre": { "type": "string" },
            "apres": { "type": "array", "items": { "type": "string" } }
          }
        },
        "validation_editoriale": { "type": "object", "additionalProperties": true }
      }
    },

    "niveaux": { "type": "object", "additionalProperties": true },
    "reseau": { "type": "object", "additionalProperties": true },
    "fil_suivant": { "type": ["string", "null"] },

    "validation": {
      "description": "Statut scientifique. Formes acceptées ; harmonisation de vocabulaire recommandée (voir README).",
      "type": "object", "additionalProperties": true
    }
  },

  "$defs": {
    "niveau_confiance": { "enum": ["atteste", "synthese_editoriale", "comparaison", "hypothese", "editorial_summary", "editorial", "validated"] },
    "texte_bilingue": {
      "type": "object", "additionalProperties": true,
      "properties": { "fr": { "type": ["string", "null"] }, "en": { "type": ["string", "null"] } }
    },
    "bloc_edito": {
      "type": "object", "additionalProperties": true,
      "properties": {
        "fr": { "type": ["string", "null"] }, "en": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] },
        "statut": { "type": ["string", "null"] },
        "niveau_confiance": { "$ref": "#/$defs/niveau_confiance" }
      }
    },
    "adresse": {
      "type": "object", "additionalProperties": true, "required": ["volume"],
      "properties": {
        "volume": { "type": "integer" },
        "maslak": { "type": ["integer", "null"] }, "marhala": { "type": ["integer", "null"] },
        "manhaj": { "type": ["integer", "null"] }, "fann": { "type": ["integer", "null"] },
        "maqala": { "type": ["integer", "null"] }, "mawqif": { "type": ["integer", "null"] },
        "bab": { "type": ["integer", "null"] }, "qism": { "type": ["integer", "null"] },
        "taraf": { "type": ["integer", "null"] }, "fasl": { "type": ["integer", "null"] }
      }
    },
    "reference": {
      "allOf": [{ "$ref": "#/$defs/adresse" }],
      "properties": {
        "importance": { "enum": ["fondamental", "important", "secondaire"] },
        "role": { "type": ["string", "null"] }, "note": { "type": ["string", "null"] }
      }
    }
  }
}
